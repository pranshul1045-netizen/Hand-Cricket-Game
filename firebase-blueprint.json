{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile containing schoolyard preferences and roles",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "battingStyle": { "type": "string", "enum": ["Right-handed", "Left-handed"] },
        "favoriteNumber": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "role", "createdAt"]
    },
    "SchoolMatch": {
      "title": "SchoolMatch",
      "description": "Real-life Hand Cricket League school match scores",
      "type": "object",
      "properties": {
        "player1": { "type": "string" },
        "player2": { "type": "string" },
        "player1Runs": { "type": "integer" },
        "player2Runs": { "type": "integer" },
        "player1Balls": { "type": "integer" },
        "player2Balls": { "type": "integer" },
        "player1Conceded": { "type": "integer" },
        "player2Conceded": { "type": "integer" },
        "winner": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "scheduled"] },
        "date": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["player1", "player2", "player1Runs", "player2Runs", "status", "creatorId", "createdAt"]
    },
    "DigitalMatch": {
      "title": "DigitalMatch",
      "description": "Digital HCL matches played inside the app",
      "type": "object",
      "properties": {
        "playerUid": { "type": "string" },
        "playerName": { "type": "string" },
        "opponentName": { "type": "string" },
        "playerRuns": { "type": "integer" },
        "opponentRuns": { "type": "integer" },
        "winner": { "type": "string", "enum": ["player", "opponent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["playerUid", "playerName", "opponentName", "playerRuns", "opponentRuns", "winner", "createdAt"]
    },
    "PlayerStanding": {
      "title": "PlayerStanding",
      "description": "Aggregated leaderboard stats for HCL school league",
      "type": "object",
      "properties": {
        "playerName": { "type": "string" },
        "matchesPlayed": { "type": "integer" },
        "matchesWon": { "type": "integer" },
        "matchesLost": { "type": "integer" },
        "totalRunsScored": { "type": "integer" },
        "totalRunsConceded": { "type": "integer" },
        "points": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["playerName", "matchesPlayed", "matchesWon", "matchesLost", "totalRunsScored", "totalRunsConceded", "points", "updatedAt"]
    },
    "LeagueUpdate": {
      "title": "LeagueUpdate",
      "description": "Official announcements, news, and updates for HCL",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "date", "creatorId", "creatorName", "createdAt"]
    },
    "PlayerProfile": {
      "title": "PlayerProfile",
      "description": "Profile info and 4-digit PIN for HCL players",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "pin": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "pin"]
    },
    "Registration": {
      "title": "Registration",
      "description": "Sign-up details for the official HCL Digital Tournament bracket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "classSec": { "type": "string" },
        "school": { "type": "string" },
        "whatsapp": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "registeredBy": { "type": "string" }
      },
      "required": ["id", "name", "classSec", "school", "whatsapp", "createdAt", "registeredBy"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global app-wide settings and states controlled by admins",
      "type": "object",
      "properties": {
        "schoolyardLocked": { "type": "boolean" }
      },
      "required": []
    },
    "GameChallenge": {
      "title": "GameChallenge",
      "description": "Real-time game challenge request and active multiplayer game state between players",
      "type": "object",
      "properties": {
        "challengerId": { "type": "string" },
        "challengerName": { "type": "string" },
        "challengerTeamName": { "type": "string" },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "targetTeamName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined", "timeout", "completed", "cancelled"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "tossWinner": { "type": "string" },
        "tossChoice": { "type": "string" },
        "p1Score": { "type": "integer" },
        "p2Score": { "type": "integer" },
        "currentInnings": { "type": "integer" },
        "currentTurn": { "type": "integer" },
        "p1LastMove": { "type": "integer" },
        "p2LastMove": { "type": "integer" },
        "p1MoveSubmitted": { "type": "boolean" },
        "p2MoveSubmitted": { "type": "boolean" },
        "gameEnded": { "type": "boolean" },
        "commentary": { "type": "string" },
        "lastTurnTime": { "type": "string" }
      },
      "required": ["challengerId", "challengerName", "targetId", "status", "createdAt", "updatedAt"]
    },
    "DigitalTournamentMatch": {
      "title": "DigitalTournamentMatch",
      "description": "Tournament match in the HCL Digital Tournament Bracket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "player1": { "type": "string" },
        "player2": { "type": "string" },
        "player1Runs": { "type": "integer" },
        "player2Runs": { "type": "integer" },
        "player1Balls": { "type": "integer" },
        "player2Balls": { "type": "integer" },
        "player1Conceded": { "type": "integer" },
        "player2Conceded": { "type": "integer" },
        "winner": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "scheduled"] },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "stage": { "type": "string" },
        "group": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "player1", "player2", "player1Runs", "player2Runs", "status", "creatorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User account detail"
    },
    "/digitalTournamentMatches/{matchId}": {
      "schema": "DigitalTournamentMatch",
      "description": "Matches in the official digital bracket"
    },
    "/schoolMatches/{matchId}": {
      "schema": "SchoolMatch",
      "description": "Official school match scorecards and fixtures"
    },
    "/digitalMatches/{matchId}": {
      "schema": "DigitalMatch",
      "description": "Matches played inside the app against CPU/PvP"
    },
    "/standings/{standingId}": {
      "schema": "PlayerStanding",
      "description": "Player league standings"
    },
    "/playerProfiles/{profileId}": {
      "schema": "PlayerProfile",
      "description": "Player profile and PIN details"
    },
    "/leagueUpdates/{updateId}": {
      "schema": "LeagueUpdate",
      "description": "HCL news and updates published by admins"
    },
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Tournament registration submissions"
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Global settings for tournaments"
    },
    "/gameChallenges/{challengeId}": {
      "schema": "GameChallenge",
      "description": "Real-time game invitation and match state"
    }
  }
}
