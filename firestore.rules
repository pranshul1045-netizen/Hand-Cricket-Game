rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net (The Fortress)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global reusable helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'pranshul1045@gmail.com' || 
        request.auth.token.email == 'pranshul1045@gamil.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation blueprints for each entity
    function isValidUserProfile(data) {
      return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 300))
        && (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2000))
        && data.role in ['user', 'admin']
        && (!('battingStyle' in data) || data.battingStyle == null || data.battingStyle in ['Right-handed', 'Left-handed'])
        && (!('favoriteNumber' in data) || data.favoriteNumber == null || (data.favoriteNumber is int && data.favoriteNumber >= 1 && data.favoriteNumber <= 6));
    }

    function isValidSchoolMatch(data) {
      return data.player1 is string && data.player1.size() > 0 && data.player1.size() <= 100
        && data.player2 is string && data.player2.size() > 0 && data.player2.size() <= 100
        && data.player1Runs is int && data.player1Runs >= 0 && data.player1Runs <= 1000
        && data.player2Runs is int && data.player2Runs >= 0 && data.player2Runs <= 1000
        && (!('player1Balls' in data) || (data.player1Balls is int && data.player1Balls >= 0))
        && (!('player2Balls' in data) || (data.player2Balls is int && data.player2Balls >= 0))
        && (!('player1Conceded' in data) || (data.player1Conceded is int && data.player1Conceded >= 0))
        && (!('player2Conceded' in data) || (data.player2Conceded is int && data.player2Conceded >= 0))
        && (!('winner' in data) || (data.winner is string && data.winner.size() <= 100))
        && data.status in ['completed', 'scheduled']
        && (!('date' in data) || (data.date is string && data.date.size() <= 100))
        && data.creatorId is string && data.creatorId.size() <= 128;
    }

    function isValidDigitalMatch(data) {
      return data.playerUid is string && data.playerUid == request.auth.uid
        && data.playerName is string && data.playerName.size() > 0 && data.playerName.size() <= 100
        && data.opponentName is string && data.opponentName.size() > 0 && data.opponentName.size() <= 100
        && data.playerRuns is int && data.playerRuns >= 0 && data.playerRuns <= 1000
        && data.opponentRuns is int && data.opponentRuns >= 0 && data.opponentRuns <= 1000
        && data.winner in ['player', 'opponent']
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidPlayerStanding(data) {
      return data.playerName is string && data.playerName.size() > 0 && data.playerName.size() <= 100
        && data.matchesPlayed is int && data.matchesPlayed >= 0
        && data.matchesWon is int && data.matchesWon >= 0
        && data.matchesLost is int && data.matchesLost >= 0
        && data.totalRunsScored is int && data.totalRunsScored >= 0
        && data.totalRunsConceded is int && data.totalRunsConceded >= 0
        && data.points is int && data.points >= 0
        && data.updatedAt is string && data.updatedAt.size() <= 50;
    }

    // Rules matching collections
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data) && (
        (request.resource.data.role == 'admin' && (request.auth.token.email == 'pranshul1045@gmail.com' || request.auth.token.email == 'pranshul1045@gamil.com')) ||
        (request.resource.data.role == 'user')
      ) && request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 50;
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data) 
        && request.resource.data.role == resource.data.role // Prevents self-assigned role changes
        && request.resource.data.createdAt == resource.data.createdAt; // Immutability
      allow delete: if isAdmin();
    }

    match /schoolMatches/{matchId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(matchId) && isValidSchoolMatch(request.resource.data) && request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 50;
      allow update: if isAdmin() && isValidSchoolMatch(request.resource.data)
        && request.resource.data.creatorId == resource.data.creatorId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /digitalMatches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(matchId) && isValidDigitalMatch(request.resource.data);
      allow update: if false; // Digital matches are immutable after played
      allow delete: if isAdmin() || (isSignedIn() && resource.data.playerUid == request.auth.uid);
    }

    match /standings/{standingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
